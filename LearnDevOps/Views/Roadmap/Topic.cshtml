@model LearnDevOps.Services.RoadmapTopic
@{
    ViewData["Title"] = Model.Title + " — " + ViewBag.RoadmapTitle;
    string slug      = ViewBag.Slug;
    string colorHex  = ViewBag.ColorHex ?? "#58CC02";
    string status    = ViewBag.Status ?? "not_started";
}

@section Styles {
    <link rel="stylesheet" href="~/css/roadmap.css" asp-append-version="true" />
    <style>
        .tp-page { max-width: 820px; margin: 0 auto; padding-bottom: 4rem; }

        /* ── Hero ── */
        .tp-hero {
            padding: 2rem 0 1.5rem;
            border-bottom: 2px solid var(--dq-border, #e5e7eb);
            margin-bottom: 2rem;
            animation: dqFadeUp .38s ease both;
        }

        .tp-hero-back {
            display: inline-flex; align-items: center; gap: .4rem;
            color: var(--dq-text-muted); text-decoration: none;
            font-size: .88rem; font-weight: 600; margin-bottom: 1rem;
            padding: .3rem .75rem; border-radius: 8px; border: 1.5px solid transparent;
            transition: color .15s, transform .15s, border-color .15s, background .15s;
        }
        .tp-hero-back:hover {
            color: var(--dq-heading); transform: translateX(-3px);
            border-color: var(--dq-border); background: var(--dq-bg, #f7f7f7);
        }

        .tp-hero-meta { display: flex; align-items: center; gap: .6rem; margin-bottom: .65rem; }

        .tp-roadmap-badge {
            font-size: .75rem; font-weight: 700; padding: .22rem .65rem;
            border-radius: 8px; color: #fff;
        }

        .tp-optional-badge {
            font-size: .72rem; font-weight: 700; padding: .22rem .6rem;
            border-radius: 8px; background: var(--dq-bg); color: var(--dq-text-muted);
            border: 1.5px solid var(--dq-border);
        }

        .tp-title {
            font-size: 2rem; font-weight: 900; color: var(--dq-heading);
            margin: 0 0 .75rem; letter-spacing: -.01em;
        }

        .tp-desc {
            font-size: .97rem; color: var(--dq-text); line-height: 1.7; max-width: 680px;
        }
        .tp-desc code {
            background: var(--dq-bg); padding: .15rem .4rem;
            border-radius: 4px; font-size: .84rem;
        }

        /* ── Status bar ── */
        .tp-status-bar {
            display: flex; align-items: center; gap: .7rem;
            margin-top: 1.4rem; flex-wrap: wrap;
        }

        .tp-status-label {
            font-size: .82rem; color: var(--dq-text-muted); font-weight: 600;
        }

        .tp-status-btn {
            display: inline-flex; align-items: center; gap: .35rem;
            padding: .42rem 1rem; border-radius: 10px;
            border: 2px solid var(--dq-border); background: transparent;
            font-size: .82rem; font-weight: 700; cursor: pointer;
            transition: all .18s cubic-bezier(.34,1.4,.64,1); color: var(--dq-text-muted);
            position: relative; overflow: hidden;
        }

        .tp-status-btn:hover {
            transform: translateY(-2px) scale(1.04);
            border-color: var(--dq-text-muted);
            box-shadow: 0 4px 12px rgba(0,0,0,.1);
        }

        .tp-status-btn:active { transform: scale(.97); }

        .tp-status-btn--done {
            border-color: var(--dq-border);
        }

        .tp-status-btn--active-done {
            border-color: #d97706 !important;
            background: linear-gradient(135deg, #fffbeb, #fef3c7) !important;
            color: #92400e !important;
            box-shadow: 0 3px 12px rgba(217,119,6,.2) !important;
        }

        .tp-status-btn--active-progress {
            border-color: #3b82f6 !important;
            background: linear-gradient(135deg, #eff6ff, #dbeafe) !important;
            color: #1d4ed8 !important;
            box-shadow: 0 3px 12px rgba(59,130,246,.2) !important;
        }

        .tp-status-btn--active-skip {
            border-color: #94a3b8 !important;
            background: rgba(148,163,184,.1) !important;
            color: #64748b !important;
        }

        /* ── Completion banner ── */
        .tp-completion-banner {
            display: none;
            align-items: center;
            gap: .75rem;
            margin-top: 1rem;
            padding: .75rem 1.2rem;
            border-radius: 12px;
            background: linear-gradient(135deg, #fffbeb, #fef3c7);
            border: 2px solid #f59e0b;
            color: #78350f;
            font-size: .9rem;
            font-weight: 700;
            animation: dqPopIn .4s cubic-bezier(.34,1.56,.64,1) both;
        }

        .tp-completion-banner--show { display: flex; }
        .tp-completion-icon { font-size: 1.6rem; }

        /* ── Content sections ── */
        .tp-section { margin-bottom: 2rem; animation: dqUnitSlide .35s ease both; }
        .tp-section:nth-child(1) { animation-delay: .05s; }
        .tp-section:nth-child(2) { animation-delay: .10s; }
        .tp-section:nth-child(3) { animation-delay: .15s; }
        .tp-section:nth-child(4) { animation-delay: .20s; }

        .tp-section-head {
            display: flex; align-items: center; gap: .55rem;
            font-size: 1.05rem; font-weight: 800; color: var(--dq-heading);
            margin-bottom: .9rem; padding-bottom: .5rem;
            border-bottom: 2px solid var(--dq-border);
        }

        /* ── Confetti styles (defined here, JS creates elements) ── */
        @* CSS for confetti is already in roadmap.css (.rm-confetti-piece) *@
    </style>
}

<div class="container tp-page" style="--rm-track-color: @colorHex">

    <!-- Hero -->
    <div class="tp-hero">
        <a href="/roadmap/@slug" class="tp-hero-back">
            <i class="bi bi-arrow-left"></i> @ViewBag.RoadmapEmoji @ViewBag.RoadmapTitle
        </a>
        <div class="tp-hero-meta">
            <span class="tp-roadmap-badge" style="background: @colorHex">@ViewBag.RoadmapTitle</span>
            @if (Model.IsOptional)
            {
                <span class="tp-optional-badge">⭕ Optional</span>
            }
        </div>
        <h1 class="tp-title">@Model.Title</h1>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="tp-desc">@Model.Description</p>
        }

        <!-- Status buttons -->
        <div class="tp-status-bar" id="tpStatusBar" data-slug="@slug" data-topic-id="@Model.Id" data-topic-title="@Model.Title">
            <span class="tp-status-label">Mark as:</span>
            <button class="tp-status-btn tp-status-btn--done @(status == "done" ? "tp-status-btn--active-done" : "")"
                    data-status="done">⭐ Done</button>
            <button class="tp-status-btn @(status == "in_progress" ? "tp-status-btn--active-progress" : "")"
                    data-status="in_progress">🔥 Learning</button>
            <button class="tp-status-btn @(status == "skip" ? "tp-status-btn--active-skip" : "")"
                    data-status="skip">⏭ Skip</button>
        </div>

        <!-- Completion banner (shown when marked done) -->
        <div class="tp-completion-banner @(status == "done" ? "tp-completion-banner--show" : "")" id="tpCompletionBanner">
            <span class="tp-completion-icon">🏆</span>
            <div>
                <div>Quest Complete!</div>
                <div style="font-size:.8rem;font-weight:500;opacity:.8">Keep the streak going — pick your next topic!</div>
            </div>
        </div>
    </div>

    <!-- Learning Videos -->
    @if (Model.YoutubeVideos?.Count > 0)
    {
        <div class="tp-section">
            <div class="tp-section-head"><span>📹</span> Learning Videos</div>
            <ul class="rm-video-list">
                @foreach (var v in Model.YoutubeVideos)
                {
                    <li class="rm-video-item">
                        <div class="rm-video-play">▶</div>
                        <div class="rm-video-info">
                            <div class="rm-video-title">
                                <a href="@v.Url" target="_blank" rel="noopener">@v.Title</a>
                            </div>
                            <div class="rm-video-meta">@v.Channel@(string.IsNullOrEmpty(v.Duration) ? "" : " · " + v.Duration)</div>
                        </div>
                    </li>
                }
            </ul>
        </div>
    }

    <!-- Interview Questions -->
    @if (Model.InterviewQuestions?.Count > 0)
    {
        <div class="tp-section">
            <div class="tp-section-head"><span>🎯</span> Interview Questions</div>
            <div class="rm-qa-list">
                @foreach (var qa in Model.InterviewQuestions)
                {
                    <div class="rm-qa-item">
                        <button class="rm-qa-question">
                            <span class="rm-qa-badge rm-qa-badge--q">Q</span>
                            @qa.Q
                            <span class="rm-qa-toggle">▼</span>
                        </button>
                        <div class="rm-qa-answer">
                            <div class="rm-qa-answer-inner">
                                <span class="rm-qa-badge rm-qa-badge--a">A</span> @qa.A
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Pro Tips -->
    @if (Model.Tips?.Count > 0)
    {
        <div class="tp-section">
            <div class="tp-section-head"><span>💡</span> Pro Tips</div>
            <ul class="rm-tips-list">
                @foreach (var tip in Model.Tips)
                {
                    <li class="rm-tip-item"><span class="rm-tip-icon">💡</span> @tip</li>
                }
            </ul>
        </div>
    }

    <!-- Resources -->
    @if (Model.Resources?.Count > 0)
    {
        <div class="tp-section">
            <div class="tp-section-head"><span>🔗</span> Resources</div>
            <ul class="rm-resources-list">
                @foreach (var r in Model.Resources)
                {
                    var icon = r.Type switch {
                        "official" => "📖", "course" => "🎓",
                        "tool"     => "🛠️", "video"  => "🎬",
                        _          => "📰"
                    };
                    var typeClass = "rm-resource-type--" + (r.Type ?? "article");
                    <li class="rm-resource-item">
                        <span class="rm-resource-icon">@icon</span>
                        <a href="@r.Url" target="_blank" rel="noopener" class="rm-resource-link">@r.Title</a>
                        <span class="rm-resource-type @typeClass">@(r.Type ?? "article")</span>
                    </li>
                }
            </ul>
        </div>
    }

</div>

@section Scripts {
<script>
(function () {
    'use strict';

    var bar        = document.getElementById('tpStatusBar');
    var banner     = document.getElementById('tpCompletionBanner');
    if (!bar) return;

    var slug       = bar.dataset.slug;
    var topicId    = bar.dataset.topicId;
    var topicTitle = bar.dataset.topicTitle || 'this topic';

    /* ── Confetti ── */
    function launchConfetti() {
        var colors = ['#f59e0b','#22c55e','#3b82f6','#a855f7','#ef4444','#fbbf24','#06b6d4','#ec4899'];
        for (var i = 0; i < 72; i++) {
            (function (i) {
                setTimeout(function () {
                    var piece = document.createElement('div');
                    piece.className = 'rm-confetti-piece';
                    var size = 5 + Math.random() * 7;
                    piece.style.cssText = [
                        'left:' + (Math.random() * 100) + 'vw',
                        'background:' + colors[Math.floor(Math.random() * colors.length)],
                        'width:' + size + 'px',
                        'height:' + (size * (1.2 + Math.random())) + 'px',
                        'animation-duration:' + (1.4 + Math.random() * 1.2) + 's',
                        'transform:rotate(' + Math.round(Math.random() * 360) + 'deg)'
                    ].join(';');
                    document.body.appendChild(piece);
                    setTimeout(function () { piece.remove(); }, 3200);
                }, i * 25);
            })(i);
        }
    }

    /* ── XP Popup ── */
    function showXpPopup() {
        var popup = document.createElement('div');
        popup.className = 'rm-xp-popup';
        popup.textContent = '⭐ +50 XP';
        document.body.appendChild(popup);
        setTimeout(function () { popup.remove(); }, 2600);
    }

    /* ── Q&A accordion ── */
    document.addEventListener('click', function (e) {
        var q = e.target.closest('.rm-qa-question');
        if (q) {
            q.closest('.rm-qa-item').classList.toggle('rm-qa-item--open');
            return;
        }

        /* ── Status button ── */
        var btn = e.target.closest('.tp-status-btn');
        if (btn && bar.contains(btn)) {
            var newStatus = btn.dataset.status;

            fetch('/roadmap/' + encodeURIComponent(slug) + '/topic/' + encodeURIComponent(topicId) + '/status', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status: newStatus })
            })
            .then(function (r) { return r.json(); })
            .then(function (res) {
                if (!res.success) return;

                // Clear all active classes
                bar.querySelectorAll('.tp-status-btn').forEach(function (b) {
                    b.classList.remove('tp-status-btn--active-done', 'tp-status-btn--active-progress', 'tp-status-btn--active-skip');
                });

                if (newStatus === 'done') {
                    btn.classList.add('tp-status-btn--active-done');
                    // Celebrations!
                    launchConfetti();
                    showXpPopup();
                    if (banner) banner.classList.add('tp-completion-banner--show');
                    // Store for return-to-roadmap toast
                    try { sessionStorage.setItem('rm_just_done_' + slug, topicTitle); } catch (_) {}
                } else if (newStatus === 'in_progress') {
                    btn.classList.add('tp-status-btn--active-progress');
                    if (banner) banner.classList.remove('tp-completion-banner--show');
                } else if (newStatus === 'skip') {
                    btn.classList.add('tp-status-btn--active-skip');
                    if (banner) banner.classList.remove('tp-completion-banner--show');
                }
            });
        }
    });

}());
</script>
}
