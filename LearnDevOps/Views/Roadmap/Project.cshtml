@model LearnDevOps.Services.RoadmapProject
@{
    ViewData["Title"] = Model.Title + " — " + ViewBag.RoadmapTitle;
    string slug = ViewBag.Slug;
    string colorHex = ViewBag.ColorHex ?? "#58CC02";
    string diffColor = Model.Difficulty switch {
        "beginner" => "#22c55e",
        "intermediate" => "#f59e0b",
        "advanced" => "#f97316",
        "expert" => "#ef4444",
        _ => "#6366f1"
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/roadmap.css" asp-append-version="true" />
    <style>
        .pj-page { max-width: 860px; margin: 0 auto; padding-bottom: 4rem; }

        .pj-hero {
            padding: 2.5rem 0 2rem;
            border-bottom: 2px solid var(--dq-border, #e5e7eb);
            margin-bottom: 2.5rem;
            animation: dqFadeUp .38s ease both;
        }
        .pj-hero-back {
            display: inline-flex; align-items: center; gap: .35rem;
            color: var(--dq-text-muted); text-decoration: none;
            font-size: .88rem; font-weight: 500; margin-bottom: 1.2rem;
            transition: color .15s, transform .15s;
        }
        .pj-hero-back:hover { color: var(--dq-heading); transform: translateX(-3px); }

        .pj-hero-icon {
            font-size: 3rem;
            display: block;
            margin-bottom: .75rem;
            animation: dqPopIn .5s cubic-bezier(.34,1.56,.64,1) .1s both;
        }

        .pj-hero-meta {
            display: flex; align-items: center; gap: .6rem; flex-wrap: wrap;
            margin-bottom: .75rem;
        }
        .pj-badge {
            font-size: .72rem; font-weight: 700; padding: .25rem .65rem;
            border-radius: 6px; text-transform: uppercase; letter-spacing: .04em;
        }
        .pj-badge--roadmap { color: #fff; }
        .pj-badge--difficulty { color: #fff; }
        .pj-badge--time {
            background: var(--dq-bg, #f1f5f9); color: var(--dq-text-muted);
            border: 1px solid var(--dq-border, #e5e7eb);
        }

        .pj-title {
            font-size: 2.2rem; font-weight: 800; color: var(--dq-heading);
            margin: 0 0 .85rem; line-height: 1.2;
        }
        .pj-desc {
            font-size: 1rem; color: var(--dq-text); line-height: 1.75;
            max-width: 720px;
        }

        /* Sections */
        .pj-section {
            margin-bottom: 2.2rem;
            animation: dqUnitSlide .35s ease both;
        }
        .pj-section:nth-child(1) { animation-delay: .05s; }
        .pj-section:nth-child(2) { animation-delay: .10s; }
        .pj-section:nth-child(3) { animation-delay: .15s; }
        .pj-section:nth-child(4) { animation-delay: .20s; }
        .pj-section:nth-child(5) { animation-delay: .25s; }

        .pj-section-head {
            display: flex; align-items: center; gap: .5rem;
            font-size: 1.1rem; font-weight: 700; color: var(--dq-heading);
            margin-bottom: 1rem; padding-bottom: .55rem;
            border-bottom: 2px solid var(--dq-border, #e5e7eb);
        }

        /* Objectives */
        .pj-objectives {
            list-style: none; padding: 0; margin: 0;
            display: flex; flex-direction: column; gap: .55rem;
        }
        .pj-objective {
            display: flex; align-items: flex-start; gap: .6rem;
            padding: .6rem .85rem; border-radius: 10px;
            background: color-mix(in srgb, @colorHex 6%, var(--dq-bg, #f7f7f7));
            font-size: .9rem; line-height: 1.55; color: var(--dq-text);
        }
        .pj-objective-icon {
            flex-shrink: 0; margin-top: 2px; font-size: .85rem;
        }

        /* Tasks */
        .pj-tasks {
            list-style: none; padding: 0; margin: 0;
            display: flex; flex-direction: column; gap: .65rem;
        }
        .pj-task {
            display: flex; align-items: flex-start; gap: .75rem;
            padding: .75rem 1rem; border-radius: 12px;
            background: var(--dq-card, #fff);
            border: 1.5px solid var(--dq-border, #e5e7eb);
            transition: border-color .2s, box-shadow .2s;
        }
        .pj-task:hover {
            border-color: color-mix(in srgb, @colorHex 50%, var(--dq-border));
            box-shadow: 0 2px 10px rgba(0,0,0,.06);
        }
        .pj-task--bonus {
            border-style: dashed;
            opacity: .85;
        }
        .pj-task-check {
            width: 22px; height: 22px; border-radius: 6px;
            border: 2px solid var(--dq-border, #d1d5db); background: transparent;
            cursor: pointer; flex-shrink: 0; margin-top: 2px;
            transition: all .2s ease; position: relative;
            display: flex; align-items: center; justify-content: center;
            font-size: 0; color: #fff;
        }
        .pj-task-check:hover { border-color: @colorHex; }
        .pj-task-check--done {
            background: @colorHex; border-color: @colorHex;
            font-size: .7rem;
        }
        .pj-task-info { flex: 1; min-width: 0; }
        .pj-task-title {
            font-size: .9rem; font-weight: 600; color: var(--dq-heading);
            margin-bottom: .2rem;
        }
        .pj-task-desc {
            font-size: .82rem; color: var(--dq-text-muted); line-height: 1.5;
        }
        .pj-task-bonus-badge {
            font-size: .65rem; font-weight: 700; padding: .15rem .45rem;
            border-radius: 4px; background: rgba(245,158,11,.12);
            color: #d97706; margin-left: .5rem;
        }

        /* Architecture Hints */
        .pj-hints {
            list-style: none; padding: 0; margin: 0;
            display: flex; flex-direction: column; gap: .5rem;
        }
        .pj-hint {
            display: flex; align-items: flex-start; gap: .55rem;
            padding: .55rem .8rem; border-radius: 8px;
            background: rgba(99,102,241,.06);
            border-left: 3px solid #6366f1;
            font-size: .86rem; line-height: 1.55; color: var(--dq-text);
        }
        .pj-hint-icon { flex-shrink: 0; margin-top: 1px; }

        /* Tech Stack */
        .pj-tech-stack {
            display: flex; flex-wrap: wrap; gap: .5rem;
        }
        .pj-tech-tag {
            padding: .35rem .75rem; border-radius: 8px;
            background: var(--dq-bg, #f1f5f9);
            border: 1px solid var(--dq-border, #e5e7eb);
            font-size: .82rem; font-weight: 600; color: var(--dq-heading);
            transition: all .15s ease;
        }
        .pj-tech-tag:hover {
            background: color-mix(in srgb, @colorHex 10%, var(--dq-bg, #f1f5f9));
            border-color: @colorHex;
        }

        /* Dark mode */
        [data-theme="dark"] .pj-task { background: var(--dq-card); border-color: var(--dq-border); }
        [data-theme="dark"] .pj-task:hover { border-color: color-mix(in srgb, @colorHex 50%, var(--dq-border)); }
        [data-theme="dark"] .pj-objective { background: color-mix(in srgb, @colorHex 8%, var(--dq-bg)); }
        [data-theme="dark"] .pj-hint { background: rgba(99,102,241,.1); }
        [data-theme="dark"] .pj-tech-tag { background: var(--dq-bg); border-color: var(--dq-border); }
    </style>
}

<div class="container pj-page" style="--rm-track-color: @colorHex">

    <!-- Hero -->
    <div class="pj-hero">
        <a href="/roadmap/@slug" class="pj-hero-back">
            <i class="bi bi-arrow-left"></i> @ViewBag.RoadmapEmoji @ViewBag.RoadmapTitle
        </a>
        <span class="pj-hero-icon">@Model.Icon</span>
        <div class="pj-hero-meta">
            <span class="pj-badge pj-badge--roadmap" style="background: @colorHex">@ViewBag.RoadmapTitle</span>
            <span class="pj-badge pj-badge--difficulty" style="background: @diffColor">@Model.Difficulty</span>
            @if (!string.IsNullOrEmpty(Model.EstimatedTime))
            {
                <span class="pj-badge pj-badge--time">@Model.EstimatedTime</span>
            }
        </div>
        <h1 class="pj-title">@Model.Title</h1>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="pj-desc">@Model.Description</p>
        }
    </div>

    <!-- Objectives -->
    @if (Model.Objectives?.Count > 0)
    {
        <div class="pj-section">
            <div class="pj-section-head"><span>🎯</span> Learning Objectives</div>
            <ul class="pj-objectives">
                @foreach (var obj in Model.Objectives)
                {
                    <li class="pj-objective">
                        <span class="pj-objective-icon">✅</span>
                        @obj
                    </li>
                }
            </ul>
        </div>
    }

    <!-- Architecture Hints -->
    @if (Model.ArchitectureHints?.Count > 0)
    {
        <div class="pj-section">
            <div class="pj-section-head"><span>🏛️</span> Architecture Hints</div>
            <ul class="pj-hints">
                @foreach (var hint in Model.ArchitectureHints)
                {
                    <li class="pj-hint">
                        <span class="pj-hint-icon">💡</span>
                        @hint
                    </li>
                }
            </ul>
        </div>
    }

    <!-- Tasks -->
    @if (Model.Tasks?.Count > 0)
    {
        <div class="pj-section">
            <div class="pj-section-head"><span>📋</span> Project Tasks</div>
            <ul class="pj-tasks">
                @foreach (var task in Model.Tasks)
                {
                    <li class="pj-task @(task.IsBonus ? "pj-task--bonus" : "")">
                        <button class="pj-task-check" title="Mark as done">✓</button>
                        <div class="pj-task-info">
                            <div class="pj-task-title">
                                @task.Title
                                @if (task.IsBonus)
                                {
                                    <span class="pj-task-bonus-badge">BONUS</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(task.Description))
                            {
                                <div class="pj-task-desc">@task.Description</div>
                            }
                        </div>
                    </li>
                }
            </ul>
        </div>
    }

    <!-- Tech Stack -->
    @if (Model.TechStack?.Count > 0)
    {
        <div class="pj-section">
            <div class="pj-section-head"><span>🧰</span> Tech Stack</div>
            <div class="pj-tech-stack">
                @foreach (var tech in Model.TechStack)
                {
                    <span class="pj-tech-tag">@tech</span>
                }
            </div>
        </div>
    }

    <!-- Resources -->
    @if (Model.Resources?.Count > 0)
    {
        <div class="pj-section">
            <div class="pj-section-head"><span>🔗</span> Resources</div>
            <ul class="rm-resources-list">
                @foreach (var r in Model.Resources)
                {
                    var icon = r.Type switch {
                        "official" => "📖", "course" => "🎓",
                        "tool" => "🛠️", "video" => "🎬",
                        _ => "📰"
                    };
                    var typeClass = "rm-resource-type--" + (r.Type ?? "article");
                    <li class="rm-resource-item">
                        <span class="rm-resource-icon">@icon</span>
                        <a href="@r.Url" target="_blank" rel="noopener" class="rm-resource-link">@r.Title</a>
                        <span class="rm-resource-type @typeClass">@(r.Type ?? "article")</span>
                    </li>
                }
            </ul>
        </div>
    }

</div>

@section Scripts {
<script>
(function () {
    // Task checkbox toggle
    document.addEventListener('click', function (e) {
        var btn = e.target.closest('.pj-task-check');
        if (!btn) return;
        btn.classList.toggle('pj-task-check--done');
        var task = btn.closest('.pj-task');
        if (task) {
            task.style.opacity = btn.classList.contains('pj-task-check--done') ? '.55' : '';
        }
    });
}());
</script>
}
