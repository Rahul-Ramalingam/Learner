@inject LearnDevOps.Services.IProgressService ProgressService
@inject LearnDevOps.Services.IGamificationService GamificationService
@{
    var _progress = ProgressService.GetProgress();
    var _levelTitle = GamificationService.GetLevelTitle(_progress.Level);
    var _levelPct = GamificationService.GetLevelProgressPercent(_progress.TotalXp);
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — DevOps Quest" : "DevOps Quest")</title>
    <!-- Apply saved theme BEFORE render to prevent flash -->
    <script>
        (function () {
            var t = localStorage.getItem('dq-theme');
            if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/gamification.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="dq-body">

    <nav class="navbar navbar-expand-md dq-navbar sticky-top">
        <div class="container px-3">
            <a class="navbar-brand dq-brand" asp-controller="Home" asp-action="Index">
                🚀 <span>DevOps Quest</span>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navMain" aria-controls="navMain" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMain">
                <ul class="navbar-nav me-auto mb-2 mb-md-0 gap-1">
                    <li class="nav-item">
                        <a class="nav-link dq-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                           asp-controller="Home" asp-action="Index">
                            <i class="bi bi-grid-fill"></i> Learn
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dq-nav-link dropdown-toggle @(ViewContext.RouteData.Values["controller"]?.ToString() == "Roadmap" ? "active" : "")"
                           href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-signpost-split-fill"></i> Roadmaps
                        </a>
                        <ul class="dropdown-menu dq-dropdown">
                            <li><a class="dropdown-item" href="/roadmap/docker">🐳 Docker</a></li>
                            <li><a class="dropdown-item" href="/roadmap/kubernetes">☸️ Kubernetes</a></li>
                            <li><a class="dropdown-item" href="/roadmap/aspnet-core">🔷 ASP.NET Core</a></li>
                            <li><a class="dropdown-item" href="/roadmap/system-design">🏗️ System Design</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link dq-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Profile" ? "active" : "")"
                           asp-controller="Profile" asp-action="Index">
                            <i class="bi bi-person-fill"></i> Profile
                        </a>
                    </li>
                </ul>

                <!-- XP Bar + Theme Toggle -->
                <div class="dq-navbar-xp d-flex align-items-center gap-3">
                    @if (_progress.CurrentStreak > 0)
                    {
                        <span class="dq-streak-badge" title="Day streak">
                            🔥 @_progress.CurrentStreak
                        </span>
                    }
                    <div class="dq-xp-pill" title="@_levelTitle — @_progress.TotalXp XP">
                        <span class="dq-xp-level">Lv @_progress.Level</span>
                        <div class="dq-xp-bar-wrap">
                            <div class="dq-xp-bar-fill" style="width: @_levelPct.ToString("F0")%"></div>
                        </div>
                        <span class="dq-xp-total">@_progress.TotalXp XP</span>
                    </div>
                    <button class="dq-theme-toggle" title="Switch to dark mode" aria-label="Switch to dark mode">
                        <i class="bi bi-moon-fill"></i>
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <main class="dq-main-content">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/theme.js" asp-append-version="true"></script>
    <script src="~/js/animations.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
